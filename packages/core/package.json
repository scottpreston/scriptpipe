{
  "name": "@scriptpipe/core",
  "version": "0.1.1",
  "description": "TypeScript-native pipeline organization for Node.js: turn loose scripts into layered pipelines with named assets, derived execution order, and simple steps.",
  "keywords": [
    "pipeline",
    "pipelines",
    "etl",
    "data-pipeline",
    "workflow",
    "orchestration",
    "typescript",
    "scripts",
    "dag"
  ],
  "license": "MIT",
  "author": "Scott Preston",
  "homepage": "https://scriptpipe.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottpreston/scriptpipe.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  }
}
